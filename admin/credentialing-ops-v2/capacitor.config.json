{
  "appId": "com.ennhealth.credentialing",
  "appName": "EnnHealth Credentialing",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1a2f3a",
      "showSpinner": true,
      "spinnerColor": "#c8a951"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1a2f3a"
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#1a8a7d"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
